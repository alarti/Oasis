<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Balanced Zen Stones with a glowing spiritual Moon/Orbit background -->
    
    <!-- Glowing crescent or soft halo representing the zen light (Cyan/Lila gradient) -->
    <path
        android:pathData="M54,18 C73.88,18 90,34.12 90,54 C90,73.88 73.88,90 54,90 C34.12,90 18,73.88 18,54 C18,34.12 34.12,18 54,18 Z"
        android:strokeWidth="1.5"
        android:strokeColor="#3380DEEA">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="18"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:offset="0.0" android:color="#1A80DEEA" />
                <item android:offset="0.5" android:color="#1AD0BCFF" />
                <item android:offset="1.0" android:color="#00D0BCFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing focal core aura behind the stones -->
    <path
        android:pathData="M54,36 A18,18 0,1 1,54,72 A18,18 0,1 1,54,36 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="36"
                android:startY="36"
                android:endX="72"
                android:endY="72"
                android:type="radial"
                android:gradientRadius="18">
                <item android:offset="0.0" android:color="#4080DEEA" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom Stone (Large, grounding base oval) with elegant gradient -->
    <path
        android:pathData="M 54,58 C 69.5,58 82,63.4 82,70 C 82,76.6 69.5,82 54,82 C 38.5,82 26,76.6 26,70 C 26,63.4 38.5,58 54,58 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="26"
                android:startY="58"
                android:endX="82"
                android:endY="82"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF242730" />
                <item android:offset="0.5" android:color="#FF383B47" />
                <item android:offset="1.0" android:color="#FF1A1C22" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Middle Stone (Medium oval, stacked on bottom) -->
    <path
        android:pathData="M 54,43 C 64.5,43 73,47.7 73,53.5 C 73,59.3 64.5,64 54,64 C 43.5,64 35,59.3 35,53.5 C 35,47.7 43.5,43 54,43 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="35"
                android:startY="43"
                android:endX="73"
                android:endY="64"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF434754" />
                <item android:offset="0.5" android:color="#FF5A6073" />
                <item android:offset="1.0" android:color="#FF2E313C" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top Stone (Small, spiritual crowning oval) with cyan-lila ambient shine -->
    <path
        android:pathData="M 54,31 C 60,31 65,34.4 65,38.5 C 65,42.6 60,46 54,46 C 48,46 43,42.6 43,38.5 C 43,34.4 48,31 54,31 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="43"
                android:startY="31"
                android:endX="65"
                android:endY="46"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF80DEEA" />
                <item android:offset="0.7" android:color="#FFD0BCFF" />
                <item android:offset="1.0" android:color="#FF6750A4" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
